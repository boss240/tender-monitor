# ─── Telegram Bot ────────────────────────────────
# Отримати у @BotFather → /newbot
TG_BOT_TOKEN=1234567890:ABCdefGhIjKlMnOpQrStUvWxYz

# Chat ID групи (починається з -100)
# Спосіб отримати: додати бота в групу → написати повідомлення →
# відкрити https://api.telegram.org/bot<TOKEN>/getUpdates → знайти chat.id
TG_CHAT_ID=-1001234567890

# ─── Email дайджест (необов'язково) ───────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=monitor@company.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM=monitor@company.com
EMAIL_TO=boss@company.com,team@company.com
